# ── Bestway ───────────────────────────────────────────────────────────────────
# QR code from the Bestway Connect app (Settings → Share Device).
# Required only for first-time onboarding (--onboard), can be removed afterwards.
BESTWAY_QR_CODE=RW_Share_xxxxxxxxxxxxxxxxxxxxxxxx

# API region: EU | US | CN  (default: EU)
BESTWAY_REGION=EU

# ── MQTT (IP-Symcon or any broker) ───────────────────────────────────────────
MQTT_HOST=192.168.1.x
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# ── MQTT topics (optional, defaults shown) ───────────────────────────────────
# State is published here (JSON, QoS 1, retain=true)
MQTT_TOPIC_STATE=spa/state

# Commands are received under this prefix:
#   spa/cmd/power        {"state": true|false}
#   spa/cmd/heater       {"state": true|false}
#   spa/cmd/filter       {"state": true|false}
#   spa/cmd/temperature  {"value": 38}
#   spa/cmd/bubbles      {"level": 0|40|100}
MQTT_TOPIC_CMD=spa/cmd
